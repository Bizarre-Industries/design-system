{
  "name": "@bizarre/design-system-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "engines": { "node": ">=22" },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:assets": "node scripts/build-assets.mjs",
    "build": "npm run build:tokens && npm run build:assets",
    "check:generated": "node scripts/check-generated.mjs",
    "verify": "npm test && npm run build && npm run check:generated"
  }
}
