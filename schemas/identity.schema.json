{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bizarre.industries/schemas/identity.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "companyName", "tagline", "taglineMeaning", "accent", "mark", "typography", "layoutModes", "identityModel", "productIntegration", "themeOrder"],
  "properties": {
    "schemaVersion": { "const": 4 },
    "companyName": { "const": "Bizarre Industries" },
    "tagline": { "const": "CATCH THE STARS" },
    "taglineMeaning": { "const": "Make the distant tangible" },
    "accent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": { "const": "Signal Lime" },
        "value": { "const": "#C6FF24" }
      }
    },
    "mark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "geometry", "approvedFigureColors", "mixedFigureColorAllowed"],
      "properties": {
        "name": { "const": "Gravity Well" },
        "geometry": { "const": "invariant" },
        "approvedFigureColors": { "const": ["Signal Lime", "Black"] },
        "mixedFigureColorAllowed": { "const": false }
      }
    },
    "typography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display", "stencil", "body", "mono"],
      "properties": {
        "display": { "const": "Unbounded" },
        "stencil": { "const": "Big Shoulders Stencil" },
        "body": { "const": "Hanken Grotesk" },
        "mono": { "const": "JetBrains Mono" }
      }
    },
    "layoutModes": {
      "const": ["Precision Panel", "Display Field"]
    },
    "identityModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "publicIdentity", "subbrandsAllowed", "childBrandsAllowed"],
      "properties": {
        "model": { "const": "single-identity" },
        "publicIdentity": { "const": "Bizarre Industries" },
        "subbrandsAllowed": { "const": false },
        "childBrandsAllowed": { "const": false }
      }
    },
    "productIntegration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principle", "auditBeforeStyling", "hostSystemFirst", "conflictResolution", "hostBehavior", "hostVisualLanguage", "bizarreExpression", "platformProfiles"],
      "properties": {
        "principle": { "const": "integrate-not-replace" },
        "auditBeforeStyling": { "const": true },
        "hostSystemFirst": { "const": true },
        "conflictResolution": { "const": "host-convention-wins" },
        "hostBehavior": { "const": "preserve" },
        "hostVisualLanguage": { "const": "preserve" },
        "bizarreExpression": { "const": "restrained-recognition-layer" },
        "platformProfiles": {
          "type": "object",
          "additionalProperties": false,
          "required": ["web", "ios", "macos", "other"],
          "properties": {
            "web": {
              "type": "object",
              "additionalProperties": false,
              "required": ["implementationLayer", "implementationIsVisualLanguage", "preserve"],
              "properties": {
                "implementationLayer": { "const": "host-framework" },
                "implementationIsVisualLanguage": { "const": false },
                "preserve": { "const": ["existing-component-system", "semantic-html", "browser-conventions"] }
              }
            },
            "ios": {
              "type": "object",
              "additionalProperties": false,
              "required": ["framework", "preserve"],
              "properties": {
                "framework": { "const": "SwiftUI" },
                "preserve": { "const": ["system-controls", "navigation", "typography", "accessibility", "touch-input", "motion"] }
              }
            },
            "macos": {
              "type": "object",
              "additionalProperties": false,
              "required": ["framework", "preserve"],
              "properties": {
                "framework": { "const": "SwiftUI" },
                "preserve": { "const": ["system-controls", "windows", "menus", "typography", "accessibility", "keyboard-and-precision-input", "motion"] }
              }
            },
            "other": {
              "type": "object",
              "additionalProperties": false,
              "required": ["entryCondition"],
              "properties": {
                "entryCondition": { "const": "audit-existing-infrastructure" }
              }
            }
          }
        }
      }
    },
    "themeOrder": {
      "const": ["void", "paper", "void-hicontrast", "workshop", "bone"]
    }
  }
}
