{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bizarre.industries/schemas/identity.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "companyName", "tagline", "accent", "mark", "typography", "layoutModes", "organization", "themeOrder"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "companyName": { "const": "Bizarre Industries" },
    "tagline": { "const": "CATCH THE STARS" },
    "accent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": { "const": "Signal Lime" },
        "value": { "const": "#C6FF24" }
      }
    },
    "mark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "const": "Gravity Well" }
      }
    },
    "typography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display", "stencil", "body", "mono"],
      "properties": {
        "display": { "const": "Unbounded" },
        "stencil": { "const": "Big Shoulders Stencil" },
        "body": { "const": "Hanken Grotesk" },
        "mono": { "const": "JetBrains Mono" }
      }
    },
    "layoutModes": {
      "const": ["Precision Panel", "Display Field"]
    },
    "organization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parent", "commercialArm", "foundation", "products"],
      "properties": {
        "parent": { "const": "Bizarre Industries" },
        "commercialArm": { "const": "Bizarre Labs" },
        "foundation": { "const": "Bizarre Foundation" },
        "products": { "const": ["Helling"] }
      }
    },
    "themeOrder": {
      "const": ["void", "paper", "void-hicontrast", "workshop", "bone"]
    }
  }
}
