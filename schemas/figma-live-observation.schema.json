{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bizarre.industries/schemas/figma-live-observation.schema.json",
  "title": "Bizarre Industries Figma Live Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "observationVersion",
    "figmaFileKey",
    "mutationStatus",
    "liveFigmaEvidence"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "observationVersion": { "const": "2.0.0" },
    "figmaFileKey": { "type": "string", "minLength": 1 },
    "mutationStatus": { "const": "READ_ONLY / FIGMA UNCHANGED" },
    "liveFigmaEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capturedAt",
        "captureMethod",
        "pageInventory",
        "canonicalVariables",
        "localStyles",
        "libraries",
        "legacyComponentSweep",
        "retiredLegacyVariableSweep",
        "componentRegistry"
      ],
      "properties": {
        "capturedAt": { "type": "string", "format": "date-time" },
        "captureMethod": { "type": "string", "pattern": "official Figma MCP" },
        "pageInventory": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "mcpRequestIds",
            "topLevelPageCount",
            "legacyPageCount",
            "permanentPageCount",
            "pages"
          ],
          "properties": {
            "mcpRequestIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "topLevelPageCount": { "type": "integer", "minimum": 104 },
            "legacyPageCount": { "const": 13 },
            "permanentPageCount": { "const": 104 },
            "pages": {
              "type": "array",
              "minItems": 104,
              "maxItems": 104,
              "items": { "$ref": "#/$defs/pageObservation" }
            }
          }
        },
        "canonicalVariables": {
          "type": "object",
          "additionalProperties": true,
          "required": ["mcpRequestIds", "collections", "variables"],
          "properties": {
            "mcpRequestIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "collections": {
              "type": "array",
              "minItems": 9,
              "maxItems": 9,
              "items": { "$ref": "#/$defs/variableCollection" }
            },
            "variables": {
              "type": "array",
              "minItems": 173,
              "maxItems": 173,
              "items": { "$ref": "#/$defs/variable" }
            }
          }
        },
        "localStyles": { "type": "object" },
        "libraries": { "type": "object" },
        "legacyComponentSweep": { "type": "object" },
        "retiredLegacyVariableSweep": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mcpRequestId", "formerIds", "formerNames", "liveMatches"],
          "properties": {
            "mcpRequestId": { "type": "string", "minLength": 1 },
            "formerIds": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": { "type": "string", "minLength": 1 }
            },
            "formerNames": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": { "type": "string", "minLength": 1 }
            },
            "liveMatches": { "type": "array", "maxItems": 0 }
          }
        },
        "componentRegistry": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["componentKey"],
            "properties": {
              "componentKey": { "type": "string", "minLength": 1 },
              "nodeId": { "type": "string", "minLength": 1 },
              "liveImportedNodeId": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["nodeId", "type", "name", "visible", "locked"],
      "properties": {
        "nodeId": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "visible": { "type": "boolean" },
        "locked": { "type": "boolean" },
        "rect": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "pluginData": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "pageObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectId",
        "pageId",
        "name",
        "observedChildCount",
        "classification",
        "topLevelNodes",
        "activeRoot",
        "pagePluginData"
      ],
      "properties": {
        "subjectId": { "type": "string", "pattern": "^(?:[0-9]{2}|99)\\.[0-9]{2}$" },
        "pageId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "observedChildCount": { "type": "integer", "minimum": 0 },
        "classification": {
          "enum": ["empty", "managed-current", "managed-stale", "unmanaged-conflict"]
        },
        "topLevelNodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "activeRoot": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/node" }] },
        "pagePluginData": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "variableCollection": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "id", "variableCount", "modes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "variableCount": { "type": "integer", "minimum": 1 },
        "modes": { "type": "array", "minItems": 1 }
      }
    },
    "variable": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ref", "id", "collection", "collectionId", "name", "resolvedType"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "collection": { "type": "string", "minLength": 1 },
        "collectionId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "resolvedType": { "enum": ["BOOLEAN", "COLOR", "FLOAT", "STRING"] }
      }
    }
  }
}
