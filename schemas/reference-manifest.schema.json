{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bizarre.industries/schemas/reference-manifest.schema.json",
  "title": "Bizarre governed design-reference manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "collection",
    "version",
    "status",
    "authority",
    "canonicalGeometry",
    "ownerReference",
    "generatedConcepts"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "collection": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status": { "enum": ["working-reference-set", "approved-reference-set", "retired"] },
    "authority": { "const": false },
    "canonicalGeometry": { "$ref": "#/$defs/canonicalGeometry" },
    "ownerReference": { "$ref": "#/$defs/ownerReference" },
    "generatedConcepts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/generatedConcept" }
    }
  },
  "$defs": {
    "repoPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "placementAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant", "path", "sha256"],
      "properties": {
        "variant": { "enum": ["primary", "inverse", "transparent"] },
        "path": { "$ref": "#/$defs/repoPath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "canonicalGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariantSource",
        "invariantSourceSha256",
        "geometryRule",
        "pathArraySha256",
        "viewBox",
        "placementAssets"
      ],
      "properties": {
        "invariantSource": { "$ref": "#/$defs/repoPath" },
        "invariantSourceSha256": { "$ref": "#/$defs/sha256" },
        "geometryRule": { "const": "exact-geometry" },
        "pathArraySha256": { "$ref": "#/$defs/sha256" },
        "viewBox": { "type": "string", "minLength": 1 },
        "placementAssets": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/placementAsset" }
        }
      }
    },
    "ownerReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sourcePath",
        "sha256",
        "mediaType",
        "dimensions",
        "classification",
        "scope",
        "authority",
        "publishable",
        "approvedBy",
        "approvedAt"
      ],
      "properties": {
        "path": { "$ref": "#/$defs/repoPath" },
        "sourcePath": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "mediaType": { "const": "image/png" },
        "dimensions": { "$ref": "#/$defs/dimensions" },
        "classification": { "const": "approved-visual-direction-reference" },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["visual-direction", "system-behavior", "application-language", "production-method"] }
        },
        "authority": { "const": "scoped" },
        "publishable": { "const": false },
        "approvedBy": { "const": "owner" },
        "approvedAt": { "type": "string", "format": "date" }
      }
    },
    "generatedConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "mediaType",
        "dimensions",
        "classification",
        "tool",
        "model",
        "generationId",
        "generatedAt",
        "promptPath",
        "promptSha256",
        "sourceReference",
        "authority",
        "publishable",
        "allowedUses",
        "warnings"
      ],
      "properties": {
        "path": { "$ref": "#/$defs/repoPath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "mediaType": { "const": "image/png" },
        "dimensions": { "$ref": "#/$defs/dimensions" },
        "classification": { "const": "generated-concept-reference" },
        "tool": { "const": "openai-imagegen" },
        "model": { "type": "string", "minLength": 1 },
        "generationId": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date" },
        "promptPath": { "$ref": "#/$defs/repoPath" },
        "promptSha256": { "$ref": "#/$defs/sha256" },
        "sourceReference": { "$ref": "#/$defs/repoPath" },
        "authority": { "const": false },
        "publishable": { "const": false },
        "allowedUses": {
          "const": ["affinity-vector-reconstruction", "internal-design-review"]
        },
        "warnings": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
