{
  "accessibility": {
    "focusToken": "focus.ring",
    "minimumTargetPx": 44,
    "nativeKeyboardBehavior": true,
    "nestedInteractiveElements": false,
    "targetToken": "space.12"
  },
  "attributes": {
    "component": "data-bzr-component",
    "layout": "data-bzr-layout",
    "state": "data-state",
    "theme": "data-bizarre-theme",
    "variant": "data-variant"
  },
  "components": {
    "atlas-panel": {
      "assetFit": "contain",
      "nativeElement": "figure",
      "provenanceRequired": true,
      "representations": [
        "spectral",
        "bands",
        "contour",
        "shaded-contour",
        "dots",
        "hatching",
        "grain",
        "material",
        "one-color"
      ]
    },
    "bilingual-data-panel": {
      "directionSource": "nearest-dir-attribute",
      "leadVariants": [
        "english",
        "arabic"
      ],
      "nativeElement": "section",
      "semanticPriority": "equal"
    },
    "calibration-label": {
      "nativeElement": "header",
      "requiredFields": [
        "atlas-id",
        "source",
        "state",
        "version-date"
      ],
      "states": [
        "idle",
        "ready",
        "aligned",
        "active",
        "captured",
        "released",
        "fault"
      ],
      "syntheticIdentifier": "configuration-hash"
    },
    "instrument-dial": {
      "nativeElement": "input",
      "nativeType": "range",
      "outputRequired": true
    },
    "physical-label": {
      "coordinateSpace": "physical",
      "interactive": false,
      "nativeElement": "article"
    },
    "signal-action": {
      "disabled": {
        "nativeAttribute": "disabled"
      },
      "loading": {
        "ariaAttribute": "aria-busy",
        "value": "true"
      },
      "nativeElements": [
        "a",
        "button"
      ],
      "pressed": {
        "ariaAttribute": "aria-pressed",
        "value": "true"
      },
      "states": [
        "default",
        "hover",
        "focus",
        "pressed",
        "disabled",
        "loading",
        "success",
        "error"
      ],
      "variants": [
        "primary",
        "quiet"
      ]
    },
    "status-indicator": {
      "live": "polite",
      "nativeElement": "output",
      "role": "status",
      "states": [
        "idle",
        "ready",
        "aligned",
        "active",
        "captured",
        "released",
        "fault"
      ]
    }
  },
  "infrastructure": {
    "behaviorOwner": "host-application",
    "browserBehaviorOwner": "browser-and-host-application",
    "globalResetAllowed": false,
    "hostComponentSystemRequired": true,
    "hostRootStyleOverrideAllowed": false,
    "nativePrimitives": [
      "a",
      "button",
      "input",
      "output",
      "select"
    ],
    "prohibitedRuntime": [
      "component-runtime",
      "dialog-system",
      "focus-manager",
      "form-engine",
      "router"
    ],
    "semanticHtmlRequired": true
  },
  "integration": {
    "adapterSurface": "opt-in-html-css",
    "auditBeforeStyling": true,
    "bizarreExpression": "restrained-recognition-layer",
    "conflictResolution": "host-convention-wins",
    "hostVisualLanguageOwner": "host-product-and-platform",
    "identityModel": "single-identity",
    "identityOwner": "Bizarre Industries",
    "principle": "integrate-not-replace"
  },
  "motion": {
    "durationToken": "capture.duration.ceremonial",
    "phaseOrder": [
      "approach",
      "compress",
      "eclipse",
      "lock",
      "release"
    ],
    "phases": {
      "approach": {
        "endToken": "capture.phase.approach.end",
        "startToken": "capture.phase.approach.start"
      },
      "compress": {
        "endToken": "capture.phase.compress.end",
        "startToken": "capture.phase.compress.start"
      },
      "eclipse": {
        "endToken": "capture.phase.eclipse.end",
        "startToken": "capture.phase.eclipse.start"
      },
      "lock": {
        "endToken": "capture.phase.lock.end",
        "startToken": "capture.phase.lock.start"
      },
      "release": {
        "endToken": "capture.phase.release.end",
        "startToken": "capture.phase.release.start"
      }
    },
    "reducedMotionState": "captured"
  },
  "package": "@bizarre/ui",
  "rtl": {
    "layoutSelector": ":dir(rtl)",
    "logicalPropertiesOnly": true,
    "physicalCoordinateDirection": "ltr",
    "physicalFieldSelector": "[data-bzr-coordinate-space=physical]"
  },
  "schemaVersion": 2,
  "themes": [
    "void",
    "paper",
    "void-hicontrast",
    "workshop",
    "bone"
  ]
}
