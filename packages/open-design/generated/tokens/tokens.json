{
  "atlas": {
    "$extensions": {
      "industries.bizarre": {
        "orientationFamily": [
          -38,
          -18,
          18,
          38
        ],
        "orientationUnit": "deg",
        "recognitionGrammar": [
          "bend",
          "absence",
          "signal"
        ],
        "trajectoryCount": 1
      }
    },
    "aperture": {
      "offset": {
        "$description": "Provisional construction offset retained for calibration experiments; it is not approved final geometry.",
        "$type": "number",
        "$value": 0.07
      },
      "ratio": {
        "$description": "Provisional construction ratio, not a canonical silhouette bounding-box aspect ratio.",
        "$type": "number",
        "$value": 1.618
      },
      "reveal-depth": {
        "$description": "Provisional screen-space reveal depth; physical production depth requires separate evidence.",
        "$type": "dimension",
        "$value": {
          "unit": "px",
          "value": 4
        }
      },
      "tangent-continuity": {
        "$description": "Owner-approved Continuous Lens constraint: the closed silhouette is tangent-continuous and contains no corners, straight segments, notches, chamfers, wedges, or key cuts. This qualitative invariant is canonical; numerical geometry remains provisional.",
        "$type": "boolean",
        "$value": true
      }
    },
    "atlas": {
      "compression-exponent": {
        "$type": "number",
        "$value": 1.72
