{
  "$extensions": {
    "industries.bizarre": {
      "themeOrder": ["void", "paper", "void-hicontrast", "workshop", "bone"]
    }
  },
  "modes": {
    "void": {
      "$type": "color",
      "surface": { "canvas": { "$value": "{color.neutral.void}" } },
      "text": { "primary": { "$value": "{color.neutral.ash100}" } }
    },
    "paper": {
      "$type": "color",
      "surface": { "canvas": { "$value": "{color.neutral.paper}" } },
      "text": { "primary": { "$value": "{color.neutral.ash900}" } }
    },
    "void-hicontrast": {
      "$type": "color",
      "surface": { "canvas": { "$value": "{color.neutral.black}" } },
      "text": { "primary": { "$value": "{color.neutral.paper}" } }
    },
    "workshop": {
      "$type": "color",
      "surface": { "canvas": { "$value": "{color.neutral.workshop}" } },
      "text": { "primary": { "$value": "{color.neutral.workshopText}" } }
    },
    "bone": {
      "$type": "color",
      "surface": { "canvas": { "$value": "{color.neutral.bone}" } },
      "text": { "primary": { "$value": "{color.neutral.smoke}" } }
    }
  }
}
