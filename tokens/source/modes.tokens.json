{
  "$extensions": {
    "industries.bizarre": {
      "themeOrder": ["void", "paper", "void-hicontrast", "workshop", "bone"]
    }
  },
  "modes": {
    "void": {
      "$type": "color",
      "surface": { "canvas": { "$value": { "colorSpace": "srgb", "components": [0.0549019608, 0.0549019608, 0.0549019608], "alpha": 1, "hex": "#0E0E0E" } } },
      "text": { "primary": { "$value": { "colorSpace": "srgb", "components": [0.8941176471, 0.8941176471, 0.8941176471], "alpha": 1, "hex": "#E4E4E4" } } }
    },
    "paper": {
