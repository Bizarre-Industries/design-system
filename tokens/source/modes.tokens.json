    "bone": {
      "$type": "color",
      "surface": { "canvas": { "$value": { "colorSpace": "srgb", "components": [0.9607843137, 0.9490196078, 0.9176470588], "alpha": 1, "hex": "#F5F2EA" } } },
      "text": { "primary": { "$value": { "colorSpace": "srgb", "components": [0.168627451, 0.168627451, 0.168627451], "alpha": 1, "hex": "#2B2B2B" } } }
