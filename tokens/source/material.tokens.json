    "carbon": { "$value": { "colorSpace": "srgb", "components": [0.0941176471, 0.1019607843, 0.1058823529], "alpha": 1, "hex": "#181A1B" } },
    "bakelite": { "$value": { "colorSpace": "srgb", "components": [0.1647058824, 0.1294117647, 0.1019607843], "alpha": 1, "hex": "#2A211A" } },
