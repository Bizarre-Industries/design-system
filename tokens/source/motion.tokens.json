{
  "motion": {
    "duration": {
      "$type": "duration",
      "instant": { "$value": { "value": 80, "unit": "ms" } }, "fast": { "$value": { "value": 150, "unit": "ms" } },
      "mid": { "$value": { "value": 300, "unit": "ms" } }, "slow": { "$value": { "value": 600, "unit": "ms" } },
      "epic": { "$value": { "value": 1200, "unit": "ms" } }
    },
    "easing": {
      "$type": "cubicBezier",
      "out": { "$value": [0.16, 1, 0.3, 1] }, "in": { "$value": [0.7, 0, 0.84, 0] },
      "inOut": { "$value": [0.87, 0, 0.13, 1] }, "spring": { "$value": [0.34, 1.56, 0.64, 1] }
    }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.08, "hex": "#00000014" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1, "unit": "px" }, "blur": { "value": 2, "unit": "px" }, "spread": { "value": 0, "unit": "px" } } },
    "md": { "$value": { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.12, "hex": "#0000001F" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 4, "unit": "px" }, "blur": { "value": 12, "unit": "px" }, "spread": { "value": 0, "unit": "px" } } },
    "lg": { "$value": { "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.18, "hex": "#0000002E" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 16, "unit": "px" }, "blur": { "value": 48, "unit": "px" }, "spread": { "value": 0, "unit": "px" } } },
    "signal": { "$value": { "color": { "colorSpace": "srgb", "components": [0.7764705882, 1, 0.1411764706], "alpha": 0.35, "hex": "#C6FF2459" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 0, "unit": "px" }, "blur": { "value": 40, "unit": "px" }, "spread": { "value": 0, "unit": "px" } } }
  }
}
